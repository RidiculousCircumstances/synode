SYNODE_DATABASE_URL=postgresql+asyncpg://synode:synode@127.0.0.1:15432/synode
SYNODE_CHECKPOINT_DATABASE_URL=postgresql://synode:synode@127.0.0.1:15432/synode?sslmode=disable
SYNODE_SEARXNG_URL=http://127.0.0.1:18080
SYNODE_MODEL_PROVIDER=ollama
SYNODE_OLLAMA_BASE_URL=http://127.0.0.1:11434
SYNODE_OLLAMA_MODEL=qwen2.5-coder:7b
SYNODE_MODEL_TIMEOUT_SECONDS=60
# Required only for DB-backed encrypted secrets, for example API keys used by
# openai_compatible model profiles.
# SYNODE_SECRETS_KEY=replace-with-long-random-string
SYNODE_WORKSPACE_ALLOWLIST=/home/rd/proj,/tmp
SYNODE_MCP_CONFIG_PATH=.mcp.json
SYNODE_ENABLE_POSTGRES_CHECKPOINTER=true
SYNODE_SANDBOX_BACKEND=process
SYNODE_SANDBOX_CPU_SECONDS=30
SYNODE_SANDBOX_MEMORY_MB=512
SYNODE_SANDBOX_DISK_MB=1024
SYNODE_SANDBOX_OUTPUT_MAX_BYTES=12000
SYNODE_WORKER_STALE_AFTER_SECONDS=120
SYNODE_RUN_EVENT_RETENTION_DAYS=30
SYNODE_MODEL_DELTA_RETENTION_DAYS=7
SYNODE_TOOL_AUDIT_RETENTION_DAYS=30
SYNODE_ARTIFACT_RETENTION_DAYS=30
SYNODE_ARCHIVED_THREAD_RETENTION_DAYS=90
SYNODE_API_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
# Default code also allows localhost, private LAN IPs, and *.local origins.
# Override with an empty value only when API is protected by a reverse proxy.
# SYNODE_API_CORS_ORIGIN_REGEX=
SYNODE_LANGFUSE_ENABLED=false
# Required only when SYNODE_LANGFUSE_ENABLED=true.
# SYNODE_LANGFUSE_BASE_URL=http://127.0.0.1:3001
# SYNODE_LANGFUSE_PUBLIC_KEY=pk-lf-...
# SYNODE_LANGFUSE_SECRET_KEY=sk-lf-...
