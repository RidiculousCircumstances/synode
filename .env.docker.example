# Optional docker compose overrides.
# Ollama is expected to run outside Docker on the host.
SYNODE_API_PORT=8787
SYNODE_UI_PORT=3000
SYNODE_UI_API_BASE_URL=auto
SYNODE_UI_API_PORT=8787
SYNODE_POSTGRES_PORT=15432
SYNODE_SEARXNG_PORT=18080
SYNODE_OLLAMA_BASE_URL=http://127.0.0.1:11434
SYNODE_OLLAMA_MODEL=qwen2.5-coder:7b
SYNODE_MODEL_TIMEOUT_SECONDS=60
SYNODE_SANDBOX_BACKEND=process
SYNODE_SANDBOX_CPU_SECONDS=30
SYNODE_SANDBOX_MEMORY_MB=512
SYNODE_SANDBOX_DISK_MB=1024
SYNODE_SANDBOX_OUTPUT_MAX_BYTES=12000
# Optional for docker-compose.sandbox.yaml.
SYNODE_SANDBOX_DOCKER_IMAGE=synode-sandbox:local
SYNODE_SANDBOX_DOCKER_NETWORK=none
SYNODE_SANDBOX_DOCKER_CPUS=1
SYNODE_SANDBOX_DOCKER_PIDS_LIMIT=128
SYNODE_SANDBOX_DOCKER_TMPFS_MB=64
# Must be an absolute host path if overriding the compose overlay default.
# SYNODE_SANDBOX_DOCKER_HOST_WORKSPACE=/home/you/proj/synode/var/workspaces
SYNODE_WORKER_STALE_AFTER_SECONDS=120
SYNODE_RUN_EVENT_RETENTION_DAYS=30
SYNODE_MODEL_DELTA_RETENTION_DAYS=7
SYNODE_TOOL_AUDIT_RETENTION_DAYS=30
SYNODE_ARTIFACT_RETENTION_DAYS=30
SYNODE_ARCHIVED_THREAD_RETENTION_DAYS=90
# Required only for DB-backed encrypted secrets.
# SYNODE_SECRETS_KEY=replace-with-long-random-string
