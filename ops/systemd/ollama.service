[Unit]
Description=Ollama system service for Synode
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=rd
Group=rd
ExecStart=/home/rd/.local/bin/ollama serve
Environment=OLLAMA_HOST=127.0.0.1:11434
Environment=OLLAMA_MODELS=/home/rd/.ollama/models
Restart=on-failure
RestartSec=3
WorkingDirectory=/home/rd

[Install]
WantedBy=multi-user.target
